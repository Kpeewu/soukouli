APP_NAME="Soukouli"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=soukouli_db
DB_USERNAME=soukouli
DB_PASSWORD=changeme-generate-a-strong-password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Salt utilise pour masquer les ID dans les URLs (hashids). Auto-genere au
# premier demarrage du conteneur si laisse vide ou a "changeme...". Generer
# manuellement avec `openssl rand -hex 32` si besoin. Ne jamais reutiliser
# APP_KEY.
HASHIDS_SALT=changeme-generate-a-real-random-value

# Chemins des binaires LaTeX (utilises pour la generation des bulletins/recus
# PDF). Valeurs par defaut adaptees a l'image Docker (TeX Live sur Debian).
LATEX_BIN_PATH=/usr/bin/pdflatex
LATEX_BIBTEX_PATH=/usr/bin/bibtex

# Mot de passe du compte admin initial (optionnel). Si vide, un mot de passe
# aleatoire est genere et affiche une seule fois dans les logs du conteneur
# "app" au premier demarrage : docker compose logs app
INITIAL_ADMIN_PASSWORD=

# --- Deploiement Docker -------------------------------------------------
DOCKER_IMAGE=toureydaou/soukouli
APP_VERSION=latest
APP_PORT=80
