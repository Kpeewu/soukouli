APP_NAME="Soukouli"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=soukouli_db
DB_USERNAME=soukouli
DB_PASSWORD=changeme-generate-a-strong-password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Salt utilise pour masquer les ID dans les URLs (hashids). Auto-genere au
# premier demarrage du conteneur si laisse vide ou a "changeme...". Generer
# manuellement avec `openssl rand -hex 32` si besoin. Ne jamais reutiliser
# APP_KEY.
HASHIDS_SALT=changeme-generate-a-real-random-value

# Chemins des binaires LaTeX (utilises pour la generation des bulletins/recus
# PDF). Valeurs par defaut adaptees a l'image Docker (TeX Live sur Debian).
LATEX_BIN_PATH=/usr/bin/pdflatex
LATEX_BIBTEX_PATH=/usr/bin/bibtex

# Mot de passe du compte admin initial (optionnel). Si vide, un mot de passe
# aleatoire est genere et affiche une seule fois dans les logs du conteneur
# "app" au premier demarrage : docker compose logs app
INITIAL_ADMIN_PASSWORD=

# --- Mode demonstration -------------------------------------------------
# Charge un jeu de donnees fictives complet (eleves, notes, paiements,
# absences, examens) au premier demarrage, et affiche dans l'interface une
# banniere rappelant les identifiants de test.
#
# NE JAMAIS activer sur une installation client : la commande
# `php artisan demo:reset` associee EFFACE INTEGRALEMENT la base de donnees.
DEMO_MODE=false

# Volumetrie du jeu de demonstration.
DEMO_CLASSES_PAR_PROMOTION=1
DEMO_ELEVES_MIN=15
DEMO_ELEVES_MAX=20

# Reinitialisation automatique de la demo chaque nuit (necessite
# DEMO_MODE=true). L'application renvoie des erreurs pendant ~30 secondes
# le temps de la recreation du schema.
DEMO_AUTO_RESET=false
DEMO_AUTO_RESET_TIME=03:00

# Barre de debug : desactivee explicitement. Elle suit APP_DEBUG par defaut,
# mais une demo publique ne doit en aucun cas l'exposer.
DEBUGBAR_ENABLED=false

# --- Deploiement Docker -------------------------------------------------
# Doit correspondre a l'image publiee par .github/workflows/docker-publish.yml
DOCKER_IMAGE=kpeewu/soukouli
APP_VERSION=latest
APP_PORT=80

# Interface sur laquelle APP_PORT est publie. 0.0.0.0 = joignable depuis le
# reseau (defaut). Derriere un reverse proxy sur la meme machine, mettre
# 127.0.0.1 : l'application n'est alors accessible que via le proxy.
APP_BIND_IP=0.0.0.0
